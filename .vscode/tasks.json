{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Debug Unity Build",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "-std=c++23",
                "-Wall",
                "-Wextra",
                "-fstack-protector-strong",
                "-fsanitize=address,undefined",
                "main.cpp",
                "-o",
                "${workspaceFolder}/build/db_main"
                    // Put further linker flags here
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Release Unity Build",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++23",
                "-Wall",
                "-Wextra",
                "-O2",
                "main.cpp",
                "-o",
                "${workspaceFolder}/build/main"
                    // Put further linker flags here
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": ["$gcc"]
        }
    ]

}
